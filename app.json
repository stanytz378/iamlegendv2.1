{
  "name": "iamlegendv2",
  "description": "High performance WhatsApp bot by STANY TZ with 250+ commands",
  "keywords": ["whatsapp-bot", "baileys", "I AM LEGEND", "StanyTz", "whatsapp"],
  "repository": "https://github.com/Stanytz378/iamlegendv2.1",
  "logo": "https://raw.githubusercontent.com/stanytz378/stanyimagesservers/refs/heads/main/bg.png",
  "stack": "container",
  "env": {
    "SESSION_ID": {
      "description": "Your session ID (obtain from the pairing site)",
      "required": true,
      "value": ""
    },
    "OWNER_NUMBER": {
      "description": "Your WhatsApp number with country code (no +, e.g. 255618558502)",
      "required": true,
      "value": "255787069580"
    },
    "BOT_NAME": {
      "description": "Bot display name",
      "required": false,
      "value": "ᴵ ᴬᴹ ᴸᴱᴳᴱᴺᴰ"
    },
    "BOT_OWNER": {
      "description": "Owner display name",
      "required": false,
      "value": "STANYTZ"
    },
    "PREFIXES": {
      "description": "Command prefixes separated by comma (e.g. .,!,/)",
      "required": false,
      "value": ".,!,/"
    },
    "PACKNAME": {
      "description": "Sticker pack name",
      "required": false,
      "value": "ᴵ ᴬᴹ ᴸᴱᴳᴱᴺᴰ"
    },
    "COMMAND_MODE": {
      "description": "Bot mode: public or private",
      "required": false,
