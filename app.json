    "TIMEZONE": {
      "description": "Your timezone (e.g. Africa/Nairobi)",
      "required": false,
      "value": "Africa/Nairobi"
    },
    "MONGO_URL": {
      "description": "MongoDB URL (recommended for persistent storage)",
      "required": false,
      "value": ""
    },
    "POSTGRES_URL": {
      "description": "PostgreSQL URL",
      "required": false,
      "value": ""
    },
    "MYSQL_URL": {
      "description": "MySQL URL",
      "required": false,
      "value": ""
    },
    "DB_URL": {
      "description": "SQLite database file path",
      "required": false,
      "value": ""
    },
    "REMOVEBG_KEY": {
      "description": "Remove.bg API key for background removal",
      "required": false,
      "value": ""
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  }
